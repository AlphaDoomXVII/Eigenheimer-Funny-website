<?xml version="1.0" encoding="UTF-8"?>
<!-- Fase 3: eten bestellen per dagdeel. Kolommen matchen App\Modules\Bestellen\Models\MenuItemModel::$fillable. -->
<table name="order_food" engine="InnoDB">
  <columns>
    <column name="id" type="INT" primary="true" auto_increment="true"/>
    <column name="UUID" type="VARCHAR" length="36" nullable="false" unique="true"/>
    <column name="name" type="VARCHAR" length="100" nullable="false"/>
    <column name="price" type="DECIMAL" length="8,2" nullable="false" default="0"/>
    <column name="dagdeel" type="VARCHAR" length="20" nullable="false" default="'ontbijt'"/>
    <column name="is_available" type="TINYINT" length="1" nullable="false" default="1"/>
  </columns>
</table>
